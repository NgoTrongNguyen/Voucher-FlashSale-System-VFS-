# DATABASE CONFIGURATION

DATABASE_URL=postgresql://voucher_user:voucher_pass123@localhost:5432/voucher_db
DB_ECHO=False

# REDIS CONFIGURATION

REDIS_URL=redis://localhost:6379/0
REDIS_POOL_SIZE=10
REDIS_SOCKET_TIMEOUT=5

# KAFKA CONFIGURATION

KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_VOUCHER=voucher-claims
KAFKA_GROUP_ID=voucher-consumer-group
KAFKA_AUTO_OFFSET_RESET=earliest
KAFKA_MAX_POLL_RECORDS=100

# SERVER CONFIGURATION

API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=False

# LOGGING

LOG_LEVEL=INFO

# CORS CONFIGURATION

CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]
CORS_CREDENTIALS=True
 
# BUSINESS LOGIC

CLAIM_COOLDOWN_SECONDS=1
KAFKA_PROCESS_TIMEOUT_SECONDS=15